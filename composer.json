{
  "name": "werkbot/werkbot-spam-protection",
  "description": "Werkbot Spam Protection Fields",
  "type": "silverstripe-vendormodule",
  "license": "MIT",
  "homepage": "https://github.com/werkbot/silverstripe-spam-module",
  "require": {
    "php": "^8.3",
    "silverstripe/cms": "^6",
    "silverstripe/framework": "^6",
    "silverstripe/spamprotection": "^5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "code-lts/doctum": "^5.5",
    "wernerkrauss/silverstripe-rector": "^1"
  },
  "autoload": {
    "psr-4": {
      "Werkbot\\SpamProtection\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "silverstripe/vendor-plugin": true
    }
  }
}
